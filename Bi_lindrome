# Bi_lindrome!

def is_palindrome(x):
    return x == x[::-1]

t = int(input())

for _ in range(t):
    s = input().strip()

    ok = False

    for i in range(1, len(s)):
        if is_palindrome(s[:i]) and is_palindrome(s[i:]):
            ok = True
            break

    print("YES" if ok else "NO")
