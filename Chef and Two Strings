

t = int(input())

for _ in range(t):
    s1 = input().strip()
    s2 = input().strip()

    possible = True

    for i in range(len(s1)):
        if s1[i] != s2[i] and s1[i] != '?' and s2[i] != '?':
            possible = False
            break

    if possible:
        print("Yes")
    else:
        print("No")
